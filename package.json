{
  "name": "@tools/tools",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "start:eventing:services": "npx nx run eventing:start",
    "stop:eventing:services": "npx nx run eventing:stop",
    "start:mail:services": "npx nx run mail:start",
    "stop:mail:services": "npx nx run mail:stop",
    "start:observability:services": "npx nx run observability:start",
    "stop:observability:services": "npx nx run observability:stop",
    "start:notification:services": "npx nx run notification:start",
    "stop:notification:services": "npx nx run notification:stop",
    "start:storage:services": "npx nx run storage:start",
    "stop:storage:services": "npx nx run storage:stop"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/vitest": "22.6.5",
    "@nx/web": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "4.0.9",
    "@vitest/ui": "4.0.9",
    "eslint": "~8.57.0",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.6.5",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "6.4.0",
    "vite": "^8.0.0",
    "vitest": "4.0.9"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "dependencies": {}
}
